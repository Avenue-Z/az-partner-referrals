# ── Auth.js ───────────────────────────────────────────────────────────────────
AUTH_SECRET=                    # openssl rand -base64 32
AUTH_GOOGLE_ID=                 # Google Cloud Console → Credentials → OAuth 2.0 Client ID
AUTH_GOOGLE_SECRET=             # Google Cloud Console → Credentials → OAuth 2.0 Client Secret

# ── HubSpot Service Key ───────────────────────────────────────────────────────
# Settings → Integrations → Service Keys → Create service key
# Required scopes (7 total):
#   crm.objects.contacts.read
#   crm.objects.contacts.write      ← covers contact→company v4 associations
#   crm.objects.companies.read
#   crm.objects.companies.write     ← covers company→partner v4 associations
#   crm.objects.owners.read
#   crm.objects.custom.read         ← required for custom Partners object (2-17260992)
#   crm.objects.custom.write        ← required to associate lead companies with partners
#
# Note: there is NO separate crm.objects.associations.write scope — it does not
# exist. The v4 associations API is unlocked by the object write scopes above.
HUBSPOT_ACCESS_TOKEN=

# ── App URL ───────────────────────────────────────────────────────────────────
# Must match an Authorized Redirect URI in Google Cloud Console:
#   Local:      http://localhost:3002/api/auth/callback/google
#   Production: https://<your-vercel-url>/api/auth/callback/google
NEXTAUTH_URL=http://localhost:3002

# ── Vercel KV (rate limiting) ─────────────────────────────────────────────────
# Provisioned via Vercel dashboard → Storage → Create Database → KV.
# When KV is connected, Vercel injects these automatically in production/preview.
# For local dev, copy the "REST API" values from the Vercel KV dashboard, or use
# a free Upstash Redis instance (https://upstash.com/redis).
# If both are unset, the rate limiter logs a warning and disables itself —
# the app still runs normally.
KV_REST_API_URL=
KV_REST_API_TOKEN=
