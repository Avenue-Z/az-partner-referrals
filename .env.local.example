# Auth.js
AUTH_SECRET=                    # openssl rand -base64 32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# HubSpot Service Key (Settings → Integrations → Service Keys)
# Required scopes:
#   crm.objects.contacts.read
#   crm.objects.contacts.write      ← also covers contact→company associations
#   crm.objects.companies.read
#   crm.objects.companies.write     ← also covers company→company associations
#   crm.objects.owners.read
#
# Note: there is no separate associations.write scope — it does not exist.
# The v4 associations API is unlocked by the object write scopes above.
HUBSPOT_ACCESS_TOKEN=

# App URL (for OAuth redirect)
NEXTAUTH_URL=http://localhost:3000
